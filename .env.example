# Copy to .env and fill in. Do not commit .env.

# Google Sheets
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# VK user token (Standalone app, scope wall,photos + "Доступ в любое время")
# https://vkhost.github.io/
VK_API_TOKEN=

# Community API keys for wall posts + comments (one JSON line, 17 groups)
# npm run vk:group-tokens-template
# Управление сообществом → Работа с API → Создать ключ (стена, сообщения)
VK_GROUP_TOKENS={"30706989":"...","219730088":"..."}
